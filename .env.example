# ===========================================
# ALFAZULU - VARIABLES DE ENTORNO
# ===========================================
# Instrucciones:
# 1. Copia este archivo como .env
# 2. Reemplaza los valores con tus credenciales reales
# 3. NO subas .env a Git (está en .gitignore)
# ===========================================

# Servidor
PORT=3000
NODE_ENV=development

# Supabase - OBTENER DE: https://app.supabase.com/project/_/settings/api
SUPABASE_URL=tu-supabase-url
SUPABASE_ANON_KEY=tu-supabase-anon-key

# Google Drive - OBTENER DE: Google Cloud Console
GOOGLE_DRIVE_FOLDER_ID=tu-folder-id
GOOGLE_CLIENT_ID=tu-client-id
GOOGLE_CLIENT_SECRET=tu-client-secret
GOOGLE_REFRESH_TOKEN=tu-refresh-token

# Telegram - OBTENER DE: @BotFather
TELEGRAM_BOT_TOKEN=tu-bot-token
TELEGRAM_CHAT_ID=tu-chat-id

# Seguridad - GENERAR CON: openssl rand -hex 32
API_KEY=tu-api-key-secreta
